<!-- ═══ SCRIPTS ════════════════════════════════════════════ -->
<script>
// Nav scroll
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 40);
});

// Scroll reveal
const observer = new IntersectionObserver((entries) => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) {
      setTimeout(() => e.target.classList.add('visible'), i * 60);
      observer.unobserve(e.target);
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// Tool card mouse glow
document.querySelectorAll('.tool-card').forEach(card => {
  card.addEventListener('mousemove', e => {
    const r = card.getBoundingClientRect();
    card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
    card.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
  });
});

// Filter
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const f = btn.dataset.filter;
    document.querySelectorAll('.tool-card').forEach(card => {
      const show = f === 'all' || card.dataset.cat === f;
      card.style.display = show ? '' : 'none';
    });
  });
});

// Subscribe
function handleSubscribe(e) {
  e.preventDefault();
  const msg = document.getElementById('subscribeMsg');
  const input = document.getElementById('emailInput');
  msg.style.color = '#4ade80';
  msg.textContent = '✓ ¡Suscripción confirmada! Te llegará un email de bienvenida.';
  input.value = '';
  setTimeout(() => {
    msg.style.color = '';
    msg.textContent = 'Sin spam. Cancela cuando quieras.';
  }, 4000);
}

// Mobile menu toggle (simple)
function toggleMenu() {
  const links = document.querySelector('.nav-links');
  if (links.style.display === 'flex') {
    links.style.display = '';
  } else {
    links.style.cssText = 'display:flex;flex-direction:column;position:fixed;top:70px;left:0;right:0;background:rgba(10,10,10,0.98);padding:2rem;gap:0.5rem;border-bottom:1px solid rgba(255,255,255,0.07);backdrop-filter:blur(20px);z-index:99;';
  }
}

// Close mobile menu on link click
document.querySelectorAll('.nav-links a').forEach(a => {
  a.addEventListener('click', () => {
    const links = document.querySelector('.nav-links');
    links.style.display = '';
  });
});
</script>
</body>
</html>
