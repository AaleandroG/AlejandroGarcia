<!-- ═══ TOOLS ═══════════════════════════════════════════════ -->
<section class="tools-section" id="herramientas">
  <div class="container">
    <div class="tools-header reveal">
      <div>
        <div class="section-label">Herramientas</div>
        <h2 class="section-title">Todo lo que<br>necesitas, <em>gratis.</em></h2>
      </div>
      <div class="tools-filter">
        <button class="filter-btn active" data-filter="all">Todas</button>
        <button class="filter-btn" data-filter="web">Web</button>
        <button class="filter-btn" data-filter="ia">IA</button>
        <button class="filter-btn" data-filter="productividad">Productividad</button>
      </div>
    </div>

    <div class="tools-grid" id="toolsGrid">

      <div class="tool-card reveal" data-cat="web" tabindex="0" role="link" aria-label="Generador de códigos QR">
        <div class="tool-icon">⬛</div>
        <div class="tool-name">Generador QR</div>
        <div class="tool-desc">Crea códigos QR personalizados para URLs, textos o contactos. Descarga en PNG o SVG.</div>
        <div class="tool-meta">
          <span class="tool-tag">Web</span>
          <span class="tool-arrow">↗</span>
        </div>
      </div>

      <div class="tool-card reveal" data-cat="web" tabindex="0">
        <div class="tool-icon">🕐</div>
        <div class="tool-name">Hora exacta mundial</div>
        <div class="tool-desc">Consulta la hora en cualquier ciudad del mundo. Convierte zonas horarias al instante.</div>
        <div class="tool-meta">
          <span class="tool-tag">Web</span>
          <span class="tool-arrow">↗</span>
        </div>
      </div>

      <div class="tool-card reveal" data-cat="web" tabindex="0">
        <div class="tool-icon">📐</div>
        <div class="tool-name">Conversor de unidades</div>
        <div class="tool-desc">Convierte entre miles de unidades: longitud, peso, temperatura, velocidad y mucho más.</div>
        <div class="tool-meta">
          <span class="tool-tag">Web</span>
          <span class="tool-arrow">↗</span>
        </div>
      </div>

      <div class="tool-card reveal" data-cat="ia" tabindex="0">
        <div class="tool-icon">✨</div>
        <div class="tool-name">Resumidor con IA</div>
        <div class="tool-desc">Pega cualquier texto o URL y obtén un resumen inteligente en segundos.</div>
        <div class="tool-meta">
          <span class="tool-tag ai">IA</span>
          <span class="tool-arrow">↗</span>
        </div>
      </div>

      <div class="tool-card reveal" data-cat="web" tabindex="0">
        <div class="tool-icon">🎨</div>
        <div class="tool-name">Generador de paletas</div>
        <div class="tool-desc">Crea paletas de color armoniosas para tus proyectos. Exporta en HEX, RGB o CSS.</div>
        <div class="tool-meta">
          <span class="tool-tag new">Nuevo</span>
          <span class="tool-arrow">↗</span>
        </div>
      </div>

      <div class="tool-card reveal" data-cat="productividad" tabindex="0">
        <div class="tool-icon">📝</div>
        <div class="tool-name">Utilidades de texto</div>
        <div class="tool-desc">Mayúsculas, conteo de palabras, eliminación de duplicados, formato JSON y más.</div>
        <div class="tool-meta">
          <span class="tool-tag">Productividad</span>
          <span class="tool-arrow">↗</span>
        </div>
      </div>

      <div class="tool-card reveal" data-cat="ia" tabindex="0">
        <div class="tool-icon">🤖</div>
        <div class="tool-name">Generador de prompts</div>
        <div class="tool-desc">Crea prompts optimizados para ChatGPT, Claude, Midjourney y otros modelos de IA.</div>
        <div class="tool-meta">
          <span class="tool-tag ai">IA</span>
          <span class="tool-tag new">Nuevo</span>
          <span class="tool-arrow">↗</span>
        </div>
      </div>

      <div class="tool-card reveal" data-cat="web" tabindex="0">
        <div class="tool-icon">💱</div>
        <div class="tool-name">Conversor de monedas</div>
        <div class="tool-desc">Tipos de cambio en tiempo real para más de 150 divisas internacionales.</div>
        <div class="tool-meta">
          <span class="tool-tag">Web</span>
          <span class="tool-arrow">↗</span>
        </div>
      </div>

      <div class="tool-card reveal" data-cat="productividad" tabindex="0">
        <div class="tool-icon">🔐</div>
        <div class="tool-name">Generador de contraseñas</div>
        <div class="tool-desc">Contraseñas seguras y únicas. Configura longitud, caracteres y complejidad.</div>
        <div class="tool-meta">
          <span class="tool-tag">Productividad</span>
          <span class="tool-arrow">↗</span>
        </div>
      </div>

    </div>

    <div style="text-align:center; margin-top:2.5rem;" class="reveal">
      <a href="#" class="btn-ghost">Ver todas las herramientas (20+) →</a>
    </div>
  </div>
</section>

<!-- ═══ IA ═══════════════════════════════════════════════════ -->
<section class="ai-section" id="ia">
  <div class="container">
    <div class="reveal">
      <div class="section-label">Inteligencia Artificial</div>
      <h2 class="section-title">IA que trabaja<br><em>para ti.</em></h2>
      <p class="section-desc">Herramientas y agentes de IA diseñados para acelerar tu trabajo, no para complicarlo.</p>
    </div>

    <div class="ai-grid">

      <div class="ai-card featured reveal">
        <div>
          <div class="ai-card-number">01 — Destacado</div>
          <h3 class="ai-card-title">Asistente IA personal</h3>
          <p class="ai-card-desc">Un asistente entrenado con el contexto del ecosistema Alejandro García. Responde preguntas, sugiere herramientas y te ayuda a encontrar exactamente lo que necesitas.</p>
          <div style="margin-top:1.5rem; display:flex; gap:0.75rem; flex-wrap:wrap;">
            <a href="#" class="btn-primary" style="font-size:0.82rem; padding:0.55rem 1.25rem;">Probar ahora →</a>
            <a href="#" class="btn-ghost" style="font-size:0.82rem; padding:0.55rem 1.1rem;">Saber más</a>
          </div>
        </div>
        <div class="ai-terminal">
          <div class="ai-terminal-bar">
            <div class="ai-terminal-dot" style="background:#ff5f56"></div>
            <div class="ai-terminal-dot" style="background:#ffbd2e"></div>
            <div class="ai-terminal-dot" style="background:#27c93f"></div>
            <span style="font-size:0.72rem; color:var(--faint); margin-left:auto;">asistente-ag · activo</span>
          </div>
          <div class="ai-terminal-content">
            <div><span class="cmd">tú →</span> ¿Qué herramienta uso para convertir unidades?</div>
            <div style="margin-top:0.5rem;"><span class="out">ag →</span> Te recomiendo el Conversor de unidades.</div>
            <div style="opacity:0.6; font-size:0.75rem; margin-top:0.25rem;"> Cubre más de 50 categorías: longitud, peso,<br> temperatura, velocidad, datos...</div>
            <div style="margin-top:0.75rem;"><span class="cmd">tú →</span> <span class="cursor"></span></div>
          </div>
        </div>
      </div>

      <div class="ai-card reveal" tabindex="0">
        <div class="ai-card-number">02</div>
        <h3 class="ai-card-title">Automatizaciones</h3>
        <p class="ai-card-desc">Conecta tus herramientas favoritas y automatiza flujos de trabajo repetitivos con agentes IA que aprenden de tus patrones.</p>
      </div>

      <div class="ai-card reveal" tabindex="0">
        <div class="ai-card-number">03</div>
        <h3 class="ai-card-title">API abierta</h3>
        <p class="ai-card-desc">Integra las herramientas del ecosistema en tus propias aplicaciones. Documentación completa y SDKs disponibles próximamente.</p>
      </div>

      <div class="ai-card reveal" tabindex="0">
        <div class="ai-card-number">04</div>
        <h3 class="ai-card-title">Agentes para empresas</h3>
        <p class="ai-card-desc">Soluciones de IA personalizadas para equipos y empresas. Desde chatbots hasta flujos de trabajo complejos con contexto propio.</p>
      </div>

    </div>
  </div>
</section>

<!-- ═══ ABOUT ═════════════════════════════════════════════════ -->
<section class="about-section" id="sobre-mi">
  <div class="container">
    <div class="about-grid">

      <div class="about-visual reveal">
        <div class="about-card-main">
          <div class="about-avatar">A</div>
          <div class="about-name">Alejandro García</div>
          <div class="about-role">Desarrollador · Creador digital · Estratega</div>
          <div class="about-tags">
            <span class="about-tag">Next.js</span>
            <span class="about-tag">TypeScript</span>
            <span class="about-tag">IA / LLMs</span>
            <span class="about-tag">Producto</span>
            <span class="about-tag">UX</span>
          </div>
          <div style="height:1px; background:var(--line); margin:1rem 0;"></div>
          <div style="font-size:0.8rem; color:var(--muted); line-height:1.6;">
            "Construyo herramientas que me gustaría tener. Si son útiles para mí, lo serán para más personas."
          </div>
        </div>
        <div class="float-card float-card-1">
          <div class="float-value">20+</div>
          <div class="float-label">Herramientas activas</div>
        </div>
        <div class="float-card float-card-2">
          <div style="display:flex;align-items:center;gap:0.5rem;">
            <span style="width:8px;height:8px;border-radius:50%;background:var(--green);"></span>
            <div class="float-label">Ecosistema activo</div>
          </div>
        </div>
      </div>

      <div class="about-text reveal">
        <div class="section-label">Sobre el proyecto</div>
        <h2 class="section-title">No es una web.<br>Es un <em>ecosistema.</em></h2>
        <p>
          Este proyecto nació de una idea simple: <strong>crear herramientas digitales que realmente funcionen</strong>, sin distracciones, sin anuncios y sin fricciones innecesarias.
        </p>
        <p>
          Lo que empezó como un conjunto de utilidades web está creciendo hasta convertirse en una plataforma completa con <strong>herramientas de IA, automatizaciones, recursos y aplicaciones</strong> diseñadas para durar años.
        </p>
        <p>
          Cada módulo está pensado para integrarse con los demás. Cada decisión técnica considera cómo afectará al conjunto dentro de 3 años. <strong>Escalabilidad sin deuda técnica.</strong>
        </p>
        <div class="about-links">
          <a href="#" class="about-link">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2a5 5 0 100 10A5 5 0 007 2z" stroke="currentColor" stroke-width="1.3"/><path d="M5 7s.5 2 2 2 2-2 2-2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M5.5 5h.01M8.5 5h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            Blog
          </a>
          <a href="#" class="about-link">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1.5C4 1.5 1.5 4 1.5 7S4 12.5 7 12.5c1.5 0 2-.5 2-.5V9.5S7.5 10 6.5 9C5.5 8 5.5 6 6.5 5s2.5-.5 3 0V2.5S9.5 1.5 7 1.5z" stroke="currentColor" stroke-width="1.3"/></svg>
            GitHub
          </a>
          <a href="#" class="about-link">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="2" y="2" width="10" height="10" rx="3" stroke="currentColor" stroke-width="1.3"/><circle cx="7" cy="7" r="2" stroke="currentColor" stroke-width="1.3"/><circle cx="10" cy="4" r="0.6" fill="currentColor"/></svg>
            Instagram
          </a>
          <a href="#newsletter" class="about-link">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 4l5 4 5-4M2 4h10v7H2V4z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
            Newsletter
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══ RESOURCES ════════════════════════════════════════════ -->
<section class="resources-section" id="recursos">
  <div class="container">
    <div class="reveal">
      <div class="section-label">Recursos</div>
      <h2 class="section-title">Aprende y<br><em>crece.</em></h2>
      <p class="section-desc">Guías, plantillas y recursos gratuitos para creadores y equipos que quieren avanzar.</p>
    </div>

    <div class="resources-list reveal">

      <div class="resource-item">
        <span class="resource-num">01</span>
        <div class="resource-icon">📘</div>
        <div class="resource-info">
          <div class="resource-title">Guía completa de prompts para IA</div>
          <div class="resource-desc">Más de 100 prompts listos para usar con ChatGPT, Claude y otros modelos.</div>
        </div>
        <span class="resource-badge free">Gratis</span>
        <span class="resource-arrow">↗</span>
      </div>

      <div class="resource-item">
        <span class="resource-num">02</span>
        <div class="resource-icon">🗂️</div>
        <div class="resource-info">
          <div class="resource-title">Kit de automatización para Notion</div>
          <div class="resource-desc">Templates y bases de datos para organizar proyectos, tareas y aprendizaje.</div>
        </div>
        <span class="resource-badge free">Gratis</span>
        <span class="resource-arrow">↗</span>
      </div>

      <div class="resource-item">
        <span class="resource-num">03</span>
